# ── Required ────────────────────────────────────────────────────────────────

# Powers the CopilotKit AI agent
OPENAI_API_KEY=sk-...

# Neon Postgres connection string
# Auto-injected by the Neon Vercel integration, or copy from console.neon.tech
POSTGRES_URL=postgresql://...

# QStash token for per-user scheduled digest delivery
# Get one free at console.upstash.com → QStash
QSTASH_TOKEN=


# ── Optional ────────────────────────────────────────────────────────────────

# App's own Resend key — only used as fallback if a user's key is unavailable
# Users bring their own Resend key at activation; magic links are sent through theirs
# Get one free at resend.com
RESEND_API_KEY=re_...


# ── Production only ──────────────────────────────────────────────────────────
# Set these in your Vercel dashboard before deploying.
# JWT_SECRET and ENCRYPTION_SECRET are auto-generated and saved to .env.local on first run.
# CRON_SECRET is optional locally (check is skipped if unset).

# Secret for signing JWT session tokens (any long random string)
# JWT_SECRET=

# 32-char key for encrypting stored Resend API keys
# ENCRYPTION_SECRET=

# Protects the /api/send endpoint from unauthorized QStash calls
# CRON_SECRET=

# Your deployed URL (used for magic link emails and QStash callbacks)
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
